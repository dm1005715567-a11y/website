        <content type="html">
            <![CDATA[
                    <p><img src="https://www.dmafzb.com/media/posts/2/IMG_1602.JPG" class="type:primaryImage" alt="SABRE-沙豹-Mighty-Discreet-迷你型辣椒喷雾-薄荷绿沙豹小蟋蟀" /></p>
                <div class="gallery-wrapper"><div class="gallery" data-is-empty="false" data-translation="Add images" data-columns="5">
<figure class="gallery__item"><a href="https://www.dmafzb.com/media/posts/2/gallery/IMG_1602-2.JPG" data-size="1080x1080"><img loading="lazy" src="https://www.dmafzb.com/media/posts/2/gallery/IMG_1602-2-thumbnail.JPG" alt="SABRE-沙豹-Mighty-Discreet-迷你辣椒喷雾-地铁通勤安全防护" width="768" height="768"></a>
